# bitfinite-stats (Next.js + Prisma + Redis + socket.io) — copy to .env and fill in
# PostgreSQL (Prisma datasource)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/bitfinite_stats
# Redis
REDIS_URL=redis://localhost:6379
# Electrum server (network/chain data)
ELECTRUM_HOST=127.0.0.1
ELECTRUM_PORT=50001
ELECTRUM_PROTOCOL=tcp
# SOLO ckpool log directory (seed-1, -B solo mode) -> "Solo Mining" tab
CKPOOL_LOGS_DIR=/srv/ckpool/logs
# POOL ckpool log directory (seed-3 shared pool) -> "Pool Mining" tab.
# seed-3 writes its logs to /srv/ckpool/logs ON seed-3; make them
# readable on THIS host (e.g. rsync every minute, or an sshfs mount) and point
# this at the local copy. Leave EMPTY to disable the Pool tab (shows an
# "coming online" state).
#   example cron on seed-3:  * * * * * rsync -az --delete /srv/ckpool/logs/ ckstatshost:/srv/pool-logs/
POOL_CKPOOL_LOGS_DIR=/srv/pool-logs
# runtime
NODE_ENV=production
