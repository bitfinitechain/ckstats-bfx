# bitfinite-stats (Next.js + Prisma + Redis + socket.io) — copy to .env and fill in
# PostgreSQL (Prisma datasource)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/bitfinite_stats
# Redis
REDIS_URL=redis://localhost:6379
# Electrum server (network/chain data)
ELECTRUM_HOST=127.0.0.1
ELECTRUM_PORT=50001
ELECTRUM_PROTOCOL=tcp
# ckpool log directory (pool stats source)
CKPOOL_LOGS_DIR=/srv/ckpool/logs
# runtime
NODE_ENV=production
