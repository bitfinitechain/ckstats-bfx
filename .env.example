# bitfinite-stats (Next.js + Prisma + Redis + socket.io) — copy to .env and fill in
# PostgreSQL (Prisma datasource)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/bitfinite_stats
# Redis
REDIS_URL=redis://localhost:6379
# Electrum server (network/chain data)
ELECTRUM_HOST=127.0.0.1
ELECTRUM_PORT=50001
ELECTRUM_PROTOCOL=tcp
# bitfinited JSON-RPC (node with txindex=1) — resolves each block's coinbase txid
# and its receiver address (the finder for solo/high-diff, the POOL address for the
# shared PPLNS pool). Optional: if BITFINITE_RPC_URL is unset the Payouts page still
# renders (receiver shows "pool", tx links fall back to the block).
BITFINITE_RPC_URL=http://127.0.0.1:19769
BITFINITE_RPC_USER=USER
BITFINITE_RPC_PASS=PASSWORD
# SOLO ckpool log directory (seed-1, -B solo mode) -> "Solo Mining" tab
CKPOOL_LOGS_DIR=/srv/ckpool/logs
# POOL ckpool log directory (seed-3 shared pool) -> "Pool Mining" tab.
# seed-3 writes its logs to /srv/ckpool/logs ON seed-3; make them
# readable on THIS host (e.g. rsync every minute, or an sshfs mount) and point
# this at the local copy. Leave EMPTY to disable the Pool tab (shows an
# "coming online" state).
#   example cron on seed-3:  * * * * * rsync -az --delete /srv/ckpool/logs/ ckstatshost:/srv/pool-logs/
POOL_CKPOOL_LOGS_DIR=/srv/pool-logs
# High-diff solo instance (port 3334, large/rented rigs) logs dir. Optional —
# surfaced as its own "High-Diff" tab, gated on activity (off when idle). Leave
# EMPTY to hide the tab. On seed-1 this is the rental ckpool's logdir.
RENTAL_CKPOOL_LOGS_DIR=/srv/ckpool-rental/logs
# runtime
NODE_ENV=production
